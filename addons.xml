<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>

<addon id="repository.deroudeleiw"
       name="De Roude Léiw Repository"
       version="1.0.0"
       provider-name="Neckel37">

    <extension point="xbmc.addon.repository">
        <info compressed="false">
            https://raw.githubusercontent.com/Neckel37/De-Roude-Leiw-Repo/master/addons.xml
        </info>

        <checksum>
            https://raw.githubusercontent.com/Neckel37/De-Roude-Leiw-Repo/master/addons.xml.md5
        </checksum>

        <datadir zip="true">
            https://raw.githubusercontent.com/Neckel37/De-Roude-Leiw-Repo/master/zips/
        </datadir>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>De Roude Léiw Kodi Repository</summary>
        <description>Repository for the De Roude Léiw Kodi addon</description>
        <platform>all</platform>
    </extension>

</addon>


<addon id="plugin.video.deroudeleiw"
       name="De Roude Léiw"
       version="1.0.0"
       provider-name="Neckel37">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Luxembourg streaming addon</summary>
        <description>Stream Shows and Movies</description>
        <platform>all</platform>
    </extension>

</addon>

</addons>